{
  "name": "@diamom/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --outDir dist",
    "dev": "tsx watch src/server.ts",
    "seed:researcher": "tsx src/seed.ts",
    "start": "node --enable-source-maps ./dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@diamom/contracts": "workspace:*",
    "@diamom/db": "workspace:*",
    "@fastify/jwt": "^10.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.1",
    "fastify-plugin": "^5.1.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.2"
  }
}
